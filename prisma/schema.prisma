// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id                    String     @id @default(cuid())
  name                  String
  denomination          String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  einOrTaxId            String?
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  sites                 Site[]
}

model Site {
  id                    String                  @id @default(cuid())
  organizationId        String
  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  siteName              String
  targetCycleYear       Int                     @default(2026)
  address               String?
  occupancyNotes        String?
  populationServed      String?
  daysHoursOfOperation  String?
  childrensAreasNotes   String?
  parkingLotNotes       String?
  surroundingAreaNotes  String?
  publicAccessNotes     String?
  knownSecurityConcerns String?
  notes                 String?
  sitePhotoUrl          String?
  // Law enforcement threat assessment tracking
  lawEnforcementAgency         String?
  lawEnforcementContactName    String?
  lawEnforcementContactDate    DateTime?
  lawEnforcementResponseDate   DateTime?
  lawEnforcementFindings       String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  threatAssessments     ThreatAssessment[]
  securityMeasures      ExistingSecurityMeasure[]
  projectProposals      ProjectProposal[]
  siteObservations      SiteObservation[]
  narrativeDrafts       NarrativeDraft[]
  applicationPackets    ApplicationPacket[]
  grantAnalyses         GrantAnalysis[]
  applicationDrafts     ApplicationDraft[]
}

model ThreatAssessment {
  id                  String    @id @default(cuid())
  siteId              String
  site                Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  threatType          String
  description         String?
  likelihood          Int       @default(3)
  impact              Int       @default(3)
  vulnerabilityNotes  String?
  incidentHistory     String?
  // Source of this threat assessment
  source              String    @default("self_assessed")
  sourceAgency        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  projectLinks        ProjectThreatLink[]
}

model ExistingSecurityMeasure {
  id                  String    @id @default(cuid())
  siteId              String
  site                Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category            String
  description         String?
  effectivenessRating Int       @default(3)
  gapsRemaining       String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ProjectProposal {
  id                      String    @id @default(cuid())
  siteId                  String
  site                    Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title                   String
  category                String?
  problemStatement        String?
  proposedSolution        String?
  riskReductionRationale  String?
  implementationNotes     String?
  priority                Int       @default(3)
  status                  String    @default("draft")
  notes                   String?
  // Timeline & Sustainment structured data (JSON-encoded)
  timelineJson            String?
  sustainmentJson         String?
  // User-authored narrative overrides (take priority over auto-generated)
  timelineNarrative       String?
  sustainmentNarrative    String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  budgetItems             BudgetItem[]
  threatLinks             ProjectThreatLink[]
}

model ProjectThreatLink {
  id                String          @id @default(cuid())
  projectId         String
  project           ProjectProposal @relation(fields: [projectId], references: [id], onDelete: Cascade)
  threatId          String
  threat            ThreatAssessment @relation(fields: [threatId], references: [id], onDelete: Cascade)
  @@unique([projectId, threatId])
}

model BudgetItem {
  id              String          @id @default(cuid())
  projectId       String
  project         ProjectProposal @relation(fields: [projectId], references: [id], onDelete: Cascade)
  itemName        String
  category        String?
  quantity        Int             @default(1)
  unitCost        Float           @default(0)
  totalCost       Float           @default(0)
  vendorName      String?
  vendorUrl       String?
  justification   String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model NarrativeDraft {
  id              String    @id @default(cuid())
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sectionName     String
  promptContext   String?
  generatedText   String?
  editedText      String?
  versionNumber   Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SiteObservation {
  id                  String    @id @default(cuid())
  siteId              String
  site                Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title               String
  locationDescription String?
  observationType     String?
  severity            Int       @default(3)
  notes               String?
  photoFilename       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ApplicationPacket {
  id          String    @id @default(cuid())
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  summary     String?
  status      String    @default("draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ApplicationDraft {
  id                  String               @id @default(cuid())
  siteId              String
  site                Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  version             Int
  status              String               @default("draft")
  title               String
  notes               String?
  snapshotJson        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  applicationReviews  ApplicationReview[]
}

model ApplicationReview {
  id                 String           @id @default(cuid())
  draftId            String
  draft              ApplicationDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  overallScore       Int              @default(0)
  reviewStatus       String           @default("incomplete")
  totalFindings      Int              @default(0)
  blockerCount       Int              @default(0)
  warningCount       Int              @default(0)
  suggestionCount    Int              @default(0)
  resolvedCount      Int              @default(0)
  unresolvedBlockers Int              @default(0)
  reviewJson         String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

// ─── Access control ───────────────────────────────────────────────────────────
// Who is allowed to sign in.  Admins can add/remove users; members can view.
// The ALLOWED_EMAILS env-var acts as a seed fallback when this table is empty.

model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("member")  // "admin" | "member"
  addedAt   DateTime @default(now())
  addedBy   String?                      // email of the admin who added this entry
}

model GrantAnalysis {
  id                            String   @id @default(cuid())
  siteId                        String
  site                          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  overallScore                  Int      @default(0)
  riskClarityScore              Int      @default(0)
  vulnerabilitySpecificityScore Int      @default(0)
  projectAlignmentScore         Int      @default(0)
  budgetDefensibilityScore      Int      @default(0)
  narrativeQualityScore         Int      @default(0)
  strengthsSummary              String?
  weaknessesSummary             String?
  priorityFixesSummary          String?
  analysisJson                  String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  flags                         GrantAnalysisFlag[]
  projectSnapshots              ProjectAnalysisSnapshot[]
}

model GrantAnalysisFlag {
  id                String        @id @default(cuid())
  grantAnalysisId   String
  grantAnalysis     GrantAnalysis @relation(fields: [grantAnalysisId], references: [id], onDelete: Cascade)
  severity          String
  category          String
  relatedEntityType String?
  relatedEntityId   String?
  title             String
  explanation       String
  suggestedFix      String
  createdAt         DateTime      @default(now())
}

model ProjectAnalysisSnapshot {
  id              String        @id @default(cuid())
  grantAnalysisId String
  grantAnalysis   GrantAnalysis @relation(fields: [grantAnalysisId], references: [id], onDelete: Cascade)
  projectId       String
  score           Int           @default(0)
  findingsJson    String?
  createdAt       DateTime      @default(now())
}
