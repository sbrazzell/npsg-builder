# Legacy SQLite (kept for reference, no longer used by the app)
DATABASE_URL="file:./dev.db"

# Turso (libsql) database
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Narrative generation
NARRATIVE_PROVIDER="template"

# Analyzer mode: "rules" (default), "anthropic", or "openai"
ANALYZER_PROVIDER="rules"
# Set to "anthropic" or "openai" and add API key below to enable LLM review
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Comma-separated list of allowed email addresses
ALLOWED_EMAILS="user1@example.com,user2@example.com,user3@example.com"
